---
import { LOCALE_CONFIG, getLocalizedRoute, getRouteContext } from '../lib/site.js';

const { bodyClass, bodyHtml, headHtml, lang, route } = Astro.props;
const { key, locale } = getRouteContext(route ?? '/');
const languageLinks = Object.keys(LOCALE_CONFIG).map((linkLocale) => ({
  href: getLocalizedRoute(key, linkLocale),
  isActive: linkLocale === locale,
  label: linkLocale.toUpperCase(),
}));

const backgroundVideoLoopFallback = `
(() => {
  const restartVideo = (video) => {
    video.currentTime = 0;
    const playPromise = video.play();

    if (playPromise && typeof playPromise.catch === 'function') {
      playPromise.catch(() => {});
    }
  };

  const attachLoopFallback = (video) => {
    if (!(video instanceof HTMLVideoElement)) {
      return;
    }

    video.loop = true;
    video.addEventListener('ended', () => restartVideo(video));
  };

  document
    .querySelectorAll('.elementor-background-video-hosted')
    .forEach(attachLoopFallback);
})();
`;

const languageSwitchNavigation = `
(() => {
  const nav = document.getElementById('lang-switch');

  if (!nav) {
    return;
  }

  nav.addEventListener(
    'click',
    (event) => {
      const link = event.target.closest('a[href]');

      if (!link) {
        return;
      }

      if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || event.button !== 0) {
        return;
      }

      event.preventDefault();
      event.stopPropagation();
      window.location.assign(link.href);
    },
    { capture: true },
  );
})();
`;
---

<!DOCTYPE html>
<html lang={lang || undefined}>
  <head>
    <Fragment set:html={headHtml} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    {languageLinks
      .filter((link) => !link.isActive)
      .map((link) => <link rel="prefetch" href={link.href} as="document" />)}
    <style is:inline>
      #pxl-loadding{display:none!important;opacity:0!important;visibility:hidden!important;pointer-events:none!important}
      #lang-switch{position:fixed;top:14px;left:14px;z-index:2147483647;font-family:inherit;font-size:12px;letter-spacing:.02em;pointer-events:auto}
      #lang-switch a{display:inline-block;margin-right:6px;padding:6px 8px;border-radius:6px;background:#0b1f3a;color:#fff;text-decoration:none;opacity:.9;pointer-events:auto;touch-action:manipulation;cursor:pointer;user-select:none}
      #lang-switch a.active{background:#ffffff;color:#0b1f3a;border:1px solid #0b1f3a}
    </style>
  </head>
  <body id="page-top" class={bodyClass || undefined}>
    <nav id="lang-switch" aria-label="Language switcher">
      {languageLinks.map((link) => (
        <a class={link.isActive ? 'active' : undefined} href={link.href}>
          {link.label}
        </a>
      ))}
    </nav>
    <Fragment set:html={bodyHtml} />
    <script is:inline set:html={languageSwitchNavigation} />
    <script is:inline set:html={backgroundVideoLoopFallback} />
  </body>
</html>
