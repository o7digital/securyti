---
import { LOCALE_CONFIG, getLocalizedRoute, getRouteContext } from '../lib/site.js';

const { bodyClass, bodyHtml, headHtml, lang, route } = Astro.props;
const { key, locale } = getRouteContext(route ?? '/');
const googleAnalyticsId = 'G-37YYDXYJNH';
const languageLinks = Object.keys(LOCALE_CONFIG).map((linkLocale) => ({
  href: getLocalizedRoute(key, linkLocale),
  isActive: linkLocale === locale,
  label: linkLocale.toUpperCase(),
}));

const backgroundVideoLoopFallback = `
(() => {
  const restartVideo = (video) => {
    video.currentTime = 0;
    const playPromise = video.play();

    if (playPromise && typeof playPromise.catch === 'function') {
      playPromise.catch(() => {});
    }
  };

  const attachLoopFallback = (video) => {
    if (!(video instanceof HTMLVideoElement)) {
      return;
    }

    video.loop = true;
    video.addEventListener('ended', () => restartVideo(video));
  };

  document
    .querySelectorAll('.elementor-background-video-hosted')
    .forEach(attachLoopFallback);
})();
`;

const languageSwitchNavigation = `
const navigateFromSwitchTarget = function (target) {
  const href = target && target.dataset ? target.dataset.langHref : '';

  if (!href) {
    return;
  }

  window.location.assign(href);
};

document.addEventListener('pointerdown', function (event) {
  const target = event.target;
  const control = target && typeof target.closest === 'function'
    ? target.closest('#lang-switch [data-lang-href]')
    : null;

  if (!control) {
    return;
  }

  if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) {
    return;
  }

  event.preventDefault();
  event.stopPropagation();
  event.stopImmediatePropagation();
  navigateFromSwitchTarget(control);
}, true);
`;

const languageSwitchInlineHandler =
  "if(!(event.metaKey||event.ctrlKey||event.shiftKey||event.altKey)){event.preventDefault();event.stopPropagation();window.location.assign(this.dataset.langHref);return false;}";

const googleAnalyticsBootstrap = `
window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', '${googleAnalyticsId}');
`;
---

<!DOCTYPE html>
<html lang={lang || undefined}>
  <head>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`}></script>
    <script is:inline set:html={googleAnalyticsBootstrap} />
    <Fragment set:html={headHtml} />
    <script is:inline set:html={languageSwitchNavigation} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    {languageLinks
      .filter((link) => !link.isActive)
      .map((link) => <link rel="prefetch" href={link.href} as="document" />)}
    <style is:inline>
      #pxl-loadding{display:none!important;opacity:0!important;visibility:hidden!important;pointer-events:none!important}
      #lang-switch{position:fixed;top:14px;left:14px;z-index:2147483647;font-family:inherit;font-size:12px;letter-spacing:.02em;pointer-events:auto;display:flex;gap:8px;align-items:center}
      #lang-switch button{display:inline-flex;align-items:center;justify-content:center;min-width:42px;min-height:34px;padding:8px 10px;border:0;border-radius:8px;background:#0b1f3a;color:#fff;font:inherit;line-height:1;text-decoration:none;opacity:.96;pointer-events:auto;touch-action:manipulation;cursor:pointer;user-select:none;-webkit-tap-highlight-color:transparent}
      #lang-switch button.active{background:#ffffff;color:#0b1f3a;border:1px solid #0b1f3a}
    </style>
  </head>
  <body id="page-top" class={bodyClass || undefined}>
    <nav id="lang-switch" aria-label="Language switcher">
      {languageLinks.map((link) => (
        <button
          class={link.isActive ? 'active' : undefined}
          type="button"
          data-lang-href={link.href}
          aria-pressed={link.isActive ? 'true' : 'false'}
          onpointerdown={languageSwitchInlineHandler}
          onclick={languageSwitchInlineHandler}
        >
          {link.label}
        </button>
      ))}
    </nav>
    <Fragment set:html={bodyHtml} />
    <script is:inline set:html={backgroundVideoLoopFallback} />
  </body>
</html>
